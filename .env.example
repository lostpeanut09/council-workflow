# Select which backend your council/review scripts use:
# - kilo-gateway: uses Kilo Gateway (default)
# - nim: direct NVIDIA NIM hosted OpenAI-compatible endpoint
# - requesty: Requesty router (policies/fallback chains)
# - auto: prefer Requesty if configured, else NIM if configured, else Kilo Gateway
COUNCIL_BACKEND=auto

# -----------------------------
# Kilo Gateway (OpenAI-compatible)
# -----------------------------
KILO_BASE_URL=https://api.kilo.ai/api/gateway
KILO_MODEL=kilo-auto/free
KILO_MODE_HINT=debug
# Optional if you want authenticated calls (free models work anonymously)
KILO_API_KEY=

# -----------------------------
# NVIDIA NIM hosted (OpenAI-compatible)
# Docs: https://docs.api.nvidia.com/nim/reference/create_chat_completion_v1_chat_completions_post
# Endpoint: https://integrate.api.nvidia.com/v1/chat/completions
# -----------------------------
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=nvapi-REPLACE_ME
# Replace with an actual model id returned by GET /v1/models on the NIM endpoint
NIM_MODEL=REPLACE_WITH_A_MODEL_ID_FROM_/v1/models

# -----------------------------
# Requesty router (OpenAI-compatible)
# Docs: https://docs.requesty.ai/quickstart
# Fallback policies: https://docs.requesty.ai/features/fallback-policies
# Base URL: https://router.requesty.ai/v1
# -----------------------------
REQUESTY_BASE_URL=https://router.requesty.ai/v1
REQUESTY_API_KEY=sk-REPLACE_ME
# Recommended: a fallback policy you created in Requesty dashboard, e.g. policy/sonnet
REQUESTY_MODEL=policy/REPLACE_ME

# -----------------------------
# Optional: override ONLY review scripts (leave COUNCIL_BACKEND for other tools)
# -----------------------------
REVIEW_BACKEND=
