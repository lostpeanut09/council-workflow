# Council backend selection
COUNCIL_BACKEND=nim        # nim | requesty | kilo-gateway

# NVIDIA NIM (OpenAI-compatible)
NVIDIA_NIM_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct

# Requesty gateway (OpenAI-compatible)
REQUESTY_API_KEY=...
REQUESTY_BASE_URL=https://router.requesty.ai/v1
REQUESTY_MODEL=policy/council-default

# Kilo Gateway (your existing default if you keep it)
KILO_GATEWAY_BASE_URL=https://api.kilo.ai/api/gateway
KILO_GATEWAY_MODEL=kilo-auto/free
