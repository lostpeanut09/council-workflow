{
  "$schema": "https://app.kilo.ai/config.json",
  "provider": {
    "openai-compatible": {
      "options": {
        "apiKey": "{env:OPENAI_COMPAT_API_KEY}",
        "baseURL": "{env:OPENAI_COMPAT_BASE_URL}"
      }
    }
  },
  "model": "openai-compatible/{env:OPENAI_COMPAT_MODEL}",
  "mcp": {
    "kilo-reviewer": {
      "type": "local",
      "command": [
        "node",
        "mcp/server.mjs"
      ],
      "environment": {
        "REPO_PATH": ".",
        "KILO_BASE_URL": "https://api.kilo.ai/api/gateway",
        "KILO_MODEL": "kilo-auto/free",
        "KILO_MODE_HINT": "debug"
      },
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything@2025.8.18"
      ],
      "enabled": false,
      "timeout": 10000
    },
    "filesystem": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@2025.8.21",
        "."
      ],
      "enabled": false,
      "timeout": 10000
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_TOOLSETS",
        "-e",
        "GITHUB_READ_ONLY",
        "ghcr.io/github/github-mcp-server@sha256:2ac27ef03461ef2b877031b838a7d1fd7f12b12d4ace7796d8cad91446d55959"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}",
        "GITHUB_TOOLSETS": "default",
        "GITHUB_READ_ONLY": "1"
      },
      "enabled": false,
      "timeout": 20000
    },
    "playwright": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "mcp/playwright@sha256:cde0813c418719d9019a1312c712f162c4abab45361245b4625ef29b977cce69"
      ],
      "enabled": false,
      "timeout": 20000
    }
  },
  "permission": {
    "kilo-reviewer_*": "allow"
  }
}